{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GMM",
  "version": "0.1.0",
  "identifier": "com.derekxwang.gmm",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GMM",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Derek-X-Wang/gmm/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU0OERBREUzMDU4NDQ4MEQKUldRTlNJUUY0NjJOVkFFK2VpR0ZqaitLKzFWUEZnQTZoVktLV3BQUXY3cmlHc1Z0VGdNTlo2dWwK"
    }
  }
}
